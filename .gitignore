# ─────────────────────────────────────────────
#  AdFlow Pro — .gitignore
#  Never commit secrets, build output, or deps
# ─────────────────────────────────────────────

# ── Credentials & Secrets (MOST IMPORTANT) ───
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test
.env.example
*.env
*.pem
*.key
*.cert
*.jks
secrets.json
credentials.json
.aws/
.ssh/

# ── Node modules (both backend & frontend) ───
node_modules/
backend/node_modules/
frontend/node_modules/

# ── Frontend build output ─────────────────────
frontend/dist/
frontend/build/
frontend/.vite/

# ── Backend logs & temp ───────────────────────
backend/logs/
backend/*.log
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS files ──────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editor settings ───────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.nvmrc

# ── Package manager locks (optional – choose 1)
# yarn.lock       # uncomment if using npm only
# package-lock.json  # uncomment if using yarn only

# ── Misc ──────────────────────────────────────
.cache/
.parcel-cache/
*.tgz
*.tar.gz
coverage/
.nyc_output/
.env.backup
*.sql
*.db
*.sqlite
*.sqlite3
uploads/
temp/
tmp/
